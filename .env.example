# ╔══════════════════════════════════════════════════════╗
# ║        CORTEXIA — Production Configuration           ║
# ╚══════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill ALL required values.
# Generate secrets: openssl rand -hex 32
#
# SECURITY: Never commit the .env file to version control.

# ───── Application ─────
APP_NAME=cortexia
APP_ENV=production                    # NEVER set to "development" on a public server
LOG_LEVEL=WARNING
DEBUG=false
SECRET_KEY=                           # REQUIRED — run: openssl rand -hex 32
API_KEY=                              # REQUIRED — run: openssl rand -hex 32

# ───── Database (PostgreSQL + pgvector) ─────
POSTGRES_DB=cortexia
POSTGRES_USER=cortexia
POSTGRES_PASSWORD=                    # REQUIRED — run: openssl rand -hex 24
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ───── Redis (with authentication) ─────
REDIS_PASSWORD=                       # REQUIRED — run: openssl rand -hex 16
# Redis URLs are constructed in docker-compose.yml using REDIS_PASSWORD.
# Only override these if using external Redis:
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ───── CORS ─────
# Set to your VPS IP or domain. Use HTTPS.
CORS_ORIGINS=["https://YOUR_VPS_IP"]

# ───── ML Models ─────
MODEL_BACKEND=retinaface
MODEL_CACHE_DIR=/app/models
EMBEDDING_DIM=512
DETECTION_THRESHOLD=0.5

# ───── Trust Pipeline ─────
TRUST_PIPELINE_ENABLED=true
ANTISPOOF_ENABLED=true
ANTISPOOF_THRESHOLD=0.7
RECOGNITION_THRESHOLD=0.45
UNKNOWN_THRESHOLD=0.35

# ───── Face Attributes ─────
ATTRIBUTES_ENABLED=true
AGE_ESTIMATION=true
GENDER_ESTIMATION=true
EMOTION_ESTIMATION=true

# ───── Streaming ─────
MAX_FACES_PER_FRAME=20
STREAM_FPS=15
TRACKER_MAX_AGE=30
RECOGNITION_INTERVAL_FRAMES=5

# ───── Rate Limiting ─────
RATE_LIMIT_PER_MINUTE=60

# ───── Dashboard (optional) ─────
# Set this for WebSocket authentication in the dashboard:
# VITE_API_KEY=<same value as API_KEY above>
